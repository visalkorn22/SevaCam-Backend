# =========================
# Application
# =========================
ENV=development
DEBUG=true
APP_URL=http://localhost:3000
FEATURE_SET=core

# =========================
# Docker entrypoint (optional)
# =========================
MIGRATION_SQL_PATH=/repo/scripts/001_create_tables_core.sql

# =========================
# Database (REQUIRED)
# =========================
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/booking_database
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/booking_database

# =========================
# CORS
# =========================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =========================
# Auth / Security
# =========================
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
MAGIC_LINK_TOKEN_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_SHORT_TTL_MINUTES=480
REFRESH_TOKEN_COOKIE_NAME=refresh_token
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAMESITE=lax
REFRESH_TOKEN_COOKIE_DOMAIN=
REFRESH_TOKEN_COOKIE_PATH=/
CSRF_COOKIE_NAME=csrf_token
JWT_ISSUER=
JWT_AUDIENCE=

AUTH_RATE_LIMIT_LOGIN=10
AUTH_RATE_LIMIT_REFRESH=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# =========================
# Google OAuth
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

# Session lifetime (days)
SESSION_DAYS=30

# Cookie security — adjust per deployment topology:
#   Topology A (same domain, reverse proxy): SECURE=true, SAMESITE=lax, DOMAIN=
#   Topology B (subdomains): SECURE=true, SAMESITE=lax, DOMAIN=.yourdomain.com
#   Topology C (cross-domain): SECURE=true, SAMESITE=none, DOMAIN=
COOKIE_NAME=auth_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/

# =========================
# Email Connection OAuth + Encryption
# =========================
# 32-byte key (AES-256-GCM), base64 encoded
# Generate with: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY_BASE64=

# Send-only scopes by default; set true to include read scopes.
ENABLE_EMAIL_READ=false

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback?provider=gmail

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8000/api/email/oauth/callback?provider=outlook

# =========================
# Email (SMTP)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# =========================
# Reminder Jobs
# =========================
REMINDER_LEAD_MINUTES=60
REMINDER_WINDOW_MINUTES=5
REMINDER_CRON_TOKEN=

# =========================
# Image Moderation (optional)
# =========================
IMAGE_MODERATION_ENABLED=false
IMAGE_MODERATION_PROVIDER=webhook
IMAGE_MODERATION_WEBHOOK_URL=
IMAGE_MODERATION_TIMEOUT_SECONDS=10
IMAGE_MODERATION_FAIL_CLOSED=true

# Google Vision SafeSearch
IMAGE_MODERATION_GOOGLE_THRESHOLD=LIKELY
IMAGE_MODERATION_GOOGLE_BLOCK_CATEGORIES=adult,violence,racy

# AWS Rekognition
IMAGE_MODERATION_AWS_MIN_CONFIDENCE=70
IMAGE_MODERATION_AWS_BLOCK_LABELS=Explicit Nudity,Violence,Visually Disturbing
IMAGE_MODERATION_AWS_REGION=

# Azure Content Safety
IMAGE_MODERATION_AZURE_SEVERITY_THRESHOLD=4
IMAGE_MODERATION_AZURE_CATEGORIES=Sexual,Violence
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=

# =========================
# PayWay (ABA)
# =========================
ABA_PAYWAY_API_URL=https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1
ABA_PAYWAY_CHECKOUT_PATH=/payments/purchase
ABA_PAYWAY_QR_PATH=/payments/generate-qr
ABA_PAYWAY_TRANSACTION_DETAIL_PATH=/payments/transaction-detail
ABA_PAYWAY_MERCHANT_ID=ec463298
ABA_PAYWAY_API_KEY=0cf52b1d0681d302293c3ce335bda3002b7e21c8
ABA_PAYWAY_PUBLIC_KEY=
ABA_PAYWAY_CALLBACK_URL=
# Sandbox testing: keep QR valid longer to avoid expiry during manual scan/pay.
ABA_PAYWAY_QR_LIFETIME_MINUTES=15
ABA_PAYWAY_QR_IMAGE_TEMPLATE=template3_color

# =========================
# Stripe
# =========================
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RETURN_URL=
STRIPE_CANCEL_URL=

# =========================
# Bakong KHQR
# =========================
# Get your JWT token from: https://api-bakong.nbc.gov.kh/
# Tokens expire — rotate regularly and update this value.
KHQR_JWT_TOKEN=
KHQR_CHECK_ENDPOINT=https://api-bakong.nbc.gov.kh/v1/check_transaction_by_md5

# Your Bakong account ID (individual: e.g. yourname@yourbank)
KHQR_BAKONG_ACCOUNT_ID=

# Phone number or merchant account number (shown in Bakong app)
KHQR_ACCOUNT_INFORMATION=

# Bank / institution name shown in the Bakong transaction detail
KHQR_ACQUIRING_BANK=

# Merchant display name (max 25 chars)
KHQR_MERCHANT_NAME=

# Merchant city (max 15 chars)
KHQR_MERCHANT_CITY=

# Optional labels shown in Bakong transaction detail (max 25 chars each)
KHQR_STORE_LABEL=
KHQR_TERMINAL_LABEL=

# ISO 18245 Merchant Category Code — 5999 = miscellaneous retail
KHQR_MERCHANT_CATEGORY_CODE=5999

# Default currency: USD or KHR
KHQR_DEFAULT_CURRENCY=USD

# How long to keep the QR session open before marking it expired (minutes)
KHQR_QR_LIFETIME_MINUTES=10
